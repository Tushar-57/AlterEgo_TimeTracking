# Copy to .env (same folder as docker-compose.unified.yml) before deployment
# JWT_SECRET signs and verifies all JWTs.
# Use one stable secret value across backend replicas and restarts.
# HS512 requires a strong key; keep this at least 64+ characters.
# Generate on macOS/Linux:
#   openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-characters
JWT_EXPIRATION=86400
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://localhost:3000,http://localhost:8088,https://your-timetracker-ui.vercel.app,https://your-timetracker-ui.netlify.app

OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini
OLLAMA_ENDPOINT=http://host.docker.internal:11434

# AlterEgo -> Agentic knowledge sync bridge
AGENTIC_SYNC_ENABLED=true
AGENTIC_SYNC_BASE_URL=http://agentic-backend:8000
AGENTIC_SYNC_CONNECT_TIMEOUT_MS=5000
AGENTIC_SYNC_REQUEST_TIMEOUT_MS=8000

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8088
# Optional wildcard support for preview deployments
CORS_ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app|https://.*\.netlify\.app

# Frontend build-time vars (leave empty to keep unified gateway routing)
VITE_TIMETRACKER_API_ORIGIN=
VITE_AGENTIC_API_ORIGIN=
VITE_AGENTIC_WS_ORIGIN=
